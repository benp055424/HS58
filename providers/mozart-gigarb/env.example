# === REQUIRED ===
PROVIDER_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY

# Optional but strongly recommended for reliable claims
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Marketplace source URL
MARKETPLACE_URL=https://handshake58.com

# === OPTIONAL (defaults shown) ===
PORT=3000
CHAIN_ID=137
CLAIM_THRESHOLD=1000000
PROVIDER_NAME=Mozart-GigArb
RATE_LIMIT_PER_MINUTE=30
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json
ADMIN_PASSWORD=

# Flat prices per request in USDC
PRICE_GIG_SCANNER=0.009
PRICE_PROPOSAL_DRAFTER=0.011
PRICE_CONVERSION_TRACKER=0.010
PRICE_ARBITRAGE_PLANNER=0.012

# Live ingestion controls (used when gigs[] is not provided)
# Configure a RapidAPI jobs endpoint (Upwork/Fiverr/Freelancer style data).
RAPIDAPI_KEY=
RAPIDAPI_HOST=
# Optional explicit URL. If unset, defaults to: https://${RAPIDAPI_HOST}/search
RAPIDAPI_GIGS_URL=
RAPIDAPI_GIGS_LIMIT=10
RAPIDAPI_GIGS_TIMEOUT_MS=7000
