# === REQUIRED ===
PROVIDER_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY
TAOAPP_API_KEY=your-taoapp-api-key-here

# === DRAIN / BLOCKCHAIN ===
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=137
CLAIM_THRESHOLD=1000000
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json

# === SERVER ===
PORT=3000
HOST=0.0.0.0
PROVIDER_NAME=Community-TaoApp

# === PRICING ===
PRICE_PER_REQUEST_USDC=0.005

# === RATE LIMITING ===
# TAO.app tiers: Free=10/min, Standard=75/min, Premium=300/min
RATE_LIMIT_PER_MINUTE=10

# === OPTIONAL ===
ADMIN_PASSWORD=
