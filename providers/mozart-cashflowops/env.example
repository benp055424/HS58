# === REQUIRED ===
PROVIDER_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY

# Optional but strongly recommended for reliable claims
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Marketplace source URL
MARKETPLACE_URL=https://handshake58.com

# === OPTIONAL (defaults shown) ===
PORT=3000
CHAIN_ID=137
CLAIM_THRESHOLD=1000000
PROVIDER_NAME=Mozart-CashflowOps
RATE_LIMIT_PER_MINUTE=30
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json
ADMIN_PASSWORD=

# Flat prices per request in USDC
PRICE_REVENUE_SCOREBOARD=0.009
PRICE_REINVEST_POLICY=0.012
PRICE_FLYWHEEL_TUNER=0.014
