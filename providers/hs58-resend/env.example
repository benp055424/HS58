# === DRAIN Payment Config (required) ===
PROVIDER_PRIVATE_KEY=0x...

# Recommended: Reliable Polygon RPC (free at alchemy.com or infura.io)
# Without this, the public RPC is used (rate-limited, claims may fail)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# === Resend Config (required) ===
RESEND_API_KEY=re_...

# Default "from" address (must be verified in Resend dashboard)
RESEND_DEFAULT_FROM=noreply@yourdomain.com

# Optional: Restrict allowed "from" domains (comma-separated). Empty = allow all verified domains.
# RESEND_ALLOWED_DOMAINS=yourdomain.com,anotherdomain.com

# === Pricing (optional) ===
# Price per email in USD (default: $0.003)
PRICE_PER_EMAIL=0.003

# === Anti-Abuse (optional, defaults shown) ===
# Max recipients per email (to + cc + bcc combined)
MAX_RECIPIENTS_PER_EMAIL=10
# Max email body size in bytes (html + text combined)
MAX_BODY_SIZE_BYTES=102400
# Min seconds between sends (global, Resend rate limit). Default 5 = 1 email per 5s.
MIN_EMAIL_INTERVAL_SECONDS=5
# Max emails per minute per payment channel (enqueue rate, not send rate)
RATE_LIMIT_PER_MINUTE=12
# Password for /v1/admin/* endpoints (empty = no auth)
ADMIN_PASSWORD=

# === Optional (defaults shown) ===
PORT=3000
CHAIN_ID=137
CLAIM_THRESHOLD=1000000
MARKUP_PERCENT=50
PROVIDER_NAME=HS58-Resend
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json
